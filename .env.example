# =============================================================================
# ODONTOLINK - PLANTILLA DE VARIABLES DE ENTORNO
# =============================================================================
# Este archivo es el contrato entre la aplicación y su entorno.
# Copialo a .env para desarrollo local. En producción, TODOS estos valores
# deben inyectarse a través de la UI de Dokploy (Application > Environment).
#
# Convenciones:
#   - Las variables marcadas [REQUERIDA] no tienen default en la aplicación.
#     Si faltan, el arranque aborta. Es intencional (Zero-Trust).
#   - Las variables marcadas [OPCIONAL] caen a un default seguro definido en
#     los archivos application*.properties. Sobreescribilas sólo si hace falta.
# =============================================================================


# -----------------------------------------------------------------------------
# PERFIL DE SPRING
# -----------------------------------------------------------------------------
# Selecciona qué application-<perfil>.properties se aplica sobre la
# configuración base. En Dokploy usar 'prod'.
#   dev  -> logs verbosos, ddl-auto=create, devtools habilitado
#   test -> logs moderados, ddl-auto=update
#   prod -> logs mínimos, ddl-auto=validate, respuestas de error endurecidas
# [REQUERIDA en despliegues de producción]
SPRING_PROFILES_ACTIVE=dev


# -----------------------------------------------------------------------------
# BASE DE DATOS — nombres canónicos de propiedades de Spring Boot
# -----------------------------------------------------------------------------
# URL JDBC completa. En Dokploy, pegar la 'Internal Connection URL' del
# servicio MySQL, reemplazando el host por el nombre del servicio MySQL en
# la red overlay dokploy-network. Ejemplo (producción):
#   jdbc:mysql://odontolink-db-4qssmj:3306/odontolink?sslMode=DISABLED&allowPublicKeyRetrieval=true&serverTimezone=America/Argentina/Buenos_Aires
#
# Notas:
#   - sslMode va en camelCase (MySQL Connector/J). 'sslmode' se ignora en silencio.
#   - sslMode=DISABLED es lo recomendado para la red overlay interna; el
#     tráfico nunca sale de la red privada de Docker.
#   - allowPublicKeyRetrieval=true es necesario cuando la cuenta de MySQL
#     usa caching_sha2_password sobre una conexión sin TLS.
# [REQUERIDA]
SPRING_DATASOURCE_URL=jdbc:mysql://localhost:3306/odontolink?sslMode=DISABLED&allowPublicKeyRetrieval=true&serverTimezone=America/Argentina/Buenos_Aires

# Cuenta de la base de datos. En producción, crear un usuario dedicado con
# privilegios mínimos; no desplegar con 'root'.
# [REQUERIDA]
SPRING_DATASOURCE_USERNAME=odontolink_app

# Contraseña de la base de datos.
# Recomendación: mínimo 16 caracteres, mayúsculas y minúsculas, dígitos y símbolos.
# [REQUERIDA]
SPRING_DATASOURCE_PASSWORD=your_secure_database_password_here


# -----------------------------------------------------------------------------
# JWT
# -----------------------------------------------------------------------------
# Secreto de firma. CRÍTICO — debe ser único por entorno.
# Generar con: openssl rand -hex 64
# Mínimo 256 bits (>= 64 caracteres hexadecimales).
# [REQUERIDA]
JWT_SECRET=generate_a_secure_random_secret_key_here_minimum_64_chars

# Tiempo de vida del token en milisegundos. 86400000 = 24h, 3600000 = 1h, 604800000 = 7d.
# [OPCIONAL — default 86400000]
JWT_EXPIRATION=86400000


# -----------------------------------------------------------------------------
# SERVIDOR HTTP
# -----------------------------------------------------------------------------
# Puerto en el que escucha la JVM dentro del contenedor. Dokploy/Traefik lo
# publica externamente según lo configurado en la UI de la aplicación; hay
# que mantenerlos alineados.
# [OPCIONAL — default 8080]
SERVER_PORT=8080


# -----------------------------------------------------------------------------
# CORS
# -----------------------------------------------------------------------------
# Lista de orígenes permitidos separados por coma. En producción listar SÓLO
# los dominios reales del frontend. Los comodines no son apropiados cuando
# se envían credenciales.
# [OPCIONAL — default http://localhost:3000]
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:4200


# -----------------------------------------------------------------------------
# OBSERVABILIDAD
# -----------------------------------------------------------------------------
# Nivel raíz de logs. El perfil prod ya fuerza WARN en la raíz e INFO para
# los paquetes de la aplicación, así que esto importa sobre todo en dev/test.
# Valores válidos: TRACE, DEBUG, INFO, WARN, ERROR
# [OPCIONAL — default INFO]
LOG_LEVEL=INFO


# -----------------------------------------------------------------------------
# REGLAS DE NEGOCIO
# -----------------------------------------------------------------------------
# Estrategia de generación de slots usada por AvailabilityGenerationService.
#   FIXED   -> intervalos fijos de 30 minutos
#   DYNAMIC -> slots dimensionados por la duración real del tratamiento
# [OPCIONAL — default FIXED]
SLOT_GENERATION_STRATEGY=FIXED

# API pública de feriados argentinos. Los datos se cachean
# en la tabla non_working_days y se refrescan on-demand cuando el caché supera
# la edad configurada. Si la API no responde, se usan los datos cacheados.
# [OPCIONAL — defaults razonables]
HOLIDAYS_API_BASE_URL=
HOLIDAYS_CACHE_DURATION_DAYS=30
HOLIDAYS_CONNECT_TIMEOUT_MS=5000
HOLIDAYS_READ_TIMEOUT_MS=10000

# Zona horaria operativa de la aplicación. Toda la lógica de calendario
# (LocalDate.now(), validaciones de vigencia de ofertas, comparadores de fechas)
# se interpreta en esta zona. Cambiarla en runtime sin coordinar con los datos
# rompe los comparadores. Usar IDs IANA estándar.
#
# Sólo necesario si se quiere sobreescribir el default desde la UI de Dokploy
# o un docker-compose externo: el Dockerfile ya pinea TZ=America/Argentina/Buenos_Aires
# a nivel OS y la app la confirma desde main().
# [OPCIONAL — default America/Argentina/Buenos_Aires]
APP_TIMEZONE=America/Argentina/Buenos_Aires

# Tope de mensajes devueltos por GET /api/chat/sessions/{id}/messages cuando
# se llama sin cursor (?since=) ni paginación (?page=&size=). Devuelve los
# últimos N en orden cronológico ASC. Para historiales mayores el FE debe
# pasar a paginación explícita; el wrapper paginado lleva serverTime para
# arrancar el polling.
# [OPCIONAL — default 100]
CHAT_INITIAL_LOAD_CAP=100


# -----------------------------------------------------------------------------
# JPA / HIBERNATE (avanzado — dejar sin setear en producción)
# -----------------------------------------------------------------------------
# El perfil prod pinea spring.jpa.hibernate.ddl-auto=validate sin importar
# esta variable, que es el comportamiento seguro para producción. Sólo
# sobreescribir en dev o test si sabés lo que estás haciendo.
# Valores válidos: none | validate | update | create | create-drop
# [OPCIONAL — default update; ignorado cuando SPRING_PROFILES_ACTIVE=prod]
DDL_AUTO=update

# Activa el eco de SQL. Debe quedar en false en producción.
# [OPCIONAL — default false]
SHOW_SQL=false

# Activa el formateo bonito de SQL en logs. Debe quedar en false en producción.
# [OPCIONAL — default false]
FORMAT_SQL=false


# -----------------------------------------------------------------------------
# RECUPERACIÓN DE CONTRASEÑA (RF04)
# -----------------------------------------------------------------------------
# Ventana de vigencia del token de recuperación de contraseña, en minutos.
# El valor por defecto sigue la recomendación de OWASP para tokens de
# un solo uso entregados por email.
# [OPCIONAL — default 30]
PASSWORD_RESET_TOKEN_TTL_MINUTES=30

# URL base del frontend a la que se anexa el token para construir el enlace
# que ve el usuario en el correo.
# [OPCIONAL — default http://localhost:3000/reset-password]
PASSWORD_RESET_FRONTEND_URL=http://localhost:3000/reset-password


# -----------------------------------------------------------------------------
# OBJECT STORAGE (S3-compatible) — Foto de perfil (RF06 extension)
# -----------------------------------------------------------------------------
# Configuracion del proveedor de object storage. El backend usa AWS SDK v2
# de forma agnostica al proveedor: funciona con Cloudflare R2, AWS S3, MinIO,
# Backblaze B2 y cualquier otro S3-compliant. Cambiar de proveedor solo
# requiere actualizar estas variables; no se toca codigo.
#
# Si quedan vacias, los endpoints POST/DELETE /api/users/me/profile-picture
# responden 503 con un mensaje claro. El resto del backend arranca igual.
#
# Ejemplo Cloudflare R2:
#   STORAGE_S3_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
#   STORAGE_S3_REGION=auto
#   STORAGE_S3_BUCKET=odontolink-uploads
#   STORAGE_S3_PUBLIC_BASE_URL=https://pub-<hash>.r2.dev
#   STORAGE_S3_PATH_STYLE=false
#
# Ejemplo MinIO local (docker compose):
#   STORAGE_S3_ENDPOINT=http://localhost:9000
#   STORAGE_S3_REGION=us-east-1
#   STORAGE_S3_BUCKET=odontolink-dev
#   STORAGE_S3_PUBLIC_BASE_URL=http://localhost:9000/odontolink-dev
#   STORAGE_S3_PATH_STYLE=true
# [OPCIONAL — endpoint de fotos falla con 503 si no se configura]
STORAGE_S3_ENDPOINT=
STORAGE_S3_REGION=auto
STORAGE_S3_BUCKET=
STORAGE_S3_ACCESS_KEY_ID=
STORAGE_S3_SECRET_ACCESS_KEY=
STORAGE_S3_PUBLIC_BASE_URL=
STORAGE_S3_PATH_STYLE=false


# -----------------------------------------------------------------------------
# FOTO DE PERFIL — Limites de validacion y procesamiento
# -----------------------------------------------------------------------------
# Tamanio maximo del archivo aceptado por el endpoint dedicado, en bytes.
# Distinto del cap del subsistema multipart de Spring (5MB hardcoded).
# El default 2097152 = 2 MB es el valor recomendado para fotos de perfil.
# [OPCIONAL — default 2097152]
PROFILE_PICTURE_MAX_BYTES=2097152

# Lado del cuadrado final tras el crop centrado + resize. La imagen se
# recorta al cuadrado mayor inscrito y se reescala a NxN.
# [OPCIONAL — default 512]
PROFILE_PICTURE_TARGET_SIZE_PX=512

# Calidad de la salida JPEG (0.0 a 1.0). 0.85 ofrece buena calidad visual
# manteniendo el archivo en ~50-150 KB para retratos tipicos.
# [OPCIONAL — default 0.85]
PROFILE_PICTURE_JPEG_QUALITY=0.85


# -----------------------------------------------------------------------------
# RATE LIMITING (avanzado — defaults razonables, ajustar solo si hace falta)
# -----------------------------------------------------------------------------
# Politicas por defecto (capacidad por bucket / periodo de refill completo):
#   forgot-password por IP    -> 5 / 1h
#   forgot-password por email -> 3 / 1h
#   reset-password por IP     -> 10 / 1h
#   login por IP              -> 10 / 1min
#   change-password por user  -> 5 / 1h (solo fallos)
#
# Para sobreescribir, descomentar y ajustar. Formato Duration ISO-8601:
#   PT1M = 1 minuto; PT1H = 1 hora; PT24H = 24 horas.
#
# RATELIMIT_FORGOT_PASSWORD_IP_CAPACITY=5
# RATELIMIT_FORGOT_PASSWORD_IP_PERIOD=PT1H
# RATELIMIT_FORGOT_PASSWORD_EMAIL_CAPACITY=3
# RATELIMIT_FORGOT_PASSWORD_EMAIL_PERIOD=PT1H
# RATELIMIT_RESET_PASSWORD_IP_CAPACITY=10
# RATELIMIT_RESET_PASSWORD_IP_PERIOD=PT1H
# RATELIMIT_LOGIN_IP_CAPACITY=10
# RATELIMIT_LOGIN_IP_PERIOD=PT1M
# RATELIMIT_CHANGE_PASSWORD_USER_CAPACITY=5
# RATELIMIT_CHANGE_PASSWORD_USER_PERIOD=PT1H


# -----------------------------------------------------------------------------
# BOOTSTRAP DEL PRIMER ADMINISTRADOR
# -----------------------------------------------------------------------------
# Las siguientes variables permiten crear el primer administrador del sistema
# automáticamente al arrancar la aplicación. El bootstrap es IDEMPOTENTE: si
# el admin ya existe (mismo email), no hace absolutamente nada en los
# arranques posteriores.
#
# Cómo usarlas en Dokploy:
#   1. Cargar las tres variables OBLIGATORIAS (email, password y dni) en la
#      pestaña Environment de la aplicación.
#   2. (Opcional) Cargar las cuatro complementarias (first-name, last-name,
#      phone, birth-date). Si no se cargan, el bootstrap usa "Admin" y
#      "OdontoLink" como nombre y apellido por defecto.
#   3. Redesplegar la aplicación.
#   4. Verificar en los logs del contenedor el mensaje:
#        "Initial administrator created successfully: email='...'"
#   5. ELIMINAR las INITIAL_ADMIN_* variables de la UI de Dokploy.
#      El componente seguirá saltándose el bootstrap incluso si se dejan,
#      pero borrarlas es buena higiene de secretos.
#
# IMPORTANTE: la contraseña se hashea con BCrypt en runtime, nunca queda en
# el código ni en los logs. Generar una contraseña fuerte, por ejemplo con:
#   openssl rand -base64 24
# [OPCIONAL — sólo para el primer arranque, dejar vacío en operación normal]
INITIAL_ADMIN_EMAIL=
INITIAL_ADMIN_PASSWORD=
INITIAL_ADMIN_DNI=
INITIAL_ADMIN_FIRST_NAME=
INITIAL_ADMIN_LAST_NAME=
INITIAL_ADMIN_PHONE=
# Formato ISO yyyy-MM-dd (por ejemplo 1990-05-21). Si no es válido, se ignora.
INITIAL_ADMIN_BIRTH_DATE=


# -----------------------------------------------------------------------------
# FEEDBACK / RANKING DOCENTE (RF25 ext.)
# -----------------------------------------------------------------------------
# Tamaño mínimo de muestra para que un practicante aparezca en los charts y
# ranking del panel docente (charts/top-by-criterion y charts/practitioners-
# ranking). Un practicante con sólo 1 ó 2 feedbacks es ruido en un ranking
# comparativo. Default 3 — bajarlo a 1 en dev/staging cuando se quiera validar
# la UI sin grandes datasets.
# [OPCIONAL — default 3]
RANKING_MIN_FEEDBACK_COUNT=3

# Tamaño por default de las listas devueltas por los charts cuando el cliente
# no especifica `topN`. El cliente puede pedir más vía el query param.
# [OPCIONAL — default 10]
RANKING_CHART_DEFAULT_TOP_N=10


# -----------------------------------------------------------------------------
# AGENTE IA / CHATBOT — Módulo administrativo (RF31, RF32, RF33)
# -----------------------------------------------------------------------------
# El backend orquesta la configuración del agente y su Knowledge Base contra
# DigitalOcean Gradient AI (Agent Platform). El paciente NO usa estos
# endpoints; son exclusivos del rol ADMIN.
#
# Provisioning manual: el agente y la KB se crean una sola vez en el dashboard
# de DigitalOcean. El backend lee y actualiza esos recursos por UUID. Si las
# tres variables OBLIGATORIAS quedan vacías, los endpoints de
# /api/admin/ai-agent/** responden 503 con mensaje claro al primer uso; el
# resto del backend arranca normalmente.

# Personal Access Token de DigitalOcean con scope GenAI. Token de
# administración (distinto de la API key de inferencia del chat público,
# que NO se usa en este módulo).
# [REQUERIDA si se usa el módulo IA]
DIGITALOCEAN_ACCESS_TOKEN=

# UUID del Agente pre-provisto en el dashboard de DO. Obtenerlo de la URL
# del dashboard: https://cloud.digitalocean.com/gen-ai/agents/<UUID>. NO es
# el slug del subdominio de chat de DO Agent.
# [REQUERIDA si se usa el módulo IA]
DIGITALOCEAN_AGENT_UUID=

# UUID de la Knowledge Base pre-provista en el dashboard de DO.
# [REQUERIDA si se usa el módulo IA]
DIGITALOCEAN_KNOWLEDGE_BASE_UUID=

# Base URL del proveedor. Solo se sobrescribe para tests/staging contra un
# mock. NO incluir /v2/gen-ai al final: las rutas ya lo incluyen.
DIGITALOCEAN_ENDPOINT_BASE_URL=

# Timeouts del cliente HTTP hacia DO, en milisegundos.
# [OPCIONAL — defaults 5000 / 20000]
DO_CONNECT_TIMEOUT_MS=5000
DO_READ_TIMEOUT_MS=20000

# Tamaño máximo de archivo subido a la KB, en bytes.
# [OPCIONAL — default 10485760 = 10 MB]
AI_KB_MAX_UPLOAD_BYTES=10485760


# -----------------------------------------------------------------------------
# BUCKET DE LA KNOWLEDGE BASE — DigitalOcean Spaces dedicado
# -----------------------------------------------------------------------------
# Bucket S3-compatible donde el backend escribe los documentos de la KB.
# DigitalOcean Agent Platform los lee directamente vía spaces_data_source.
#
# IMPORTANTE: el bucket DEBE ser DigitalOcean Spaces (o AWS S3 nativo). La
# API de Gradient no acepta endpoint custom, por lo que R2/MinIO/B2 NO sirven
# para este módulo (sí sirven para STORAGE_S3_* porque ese bucket lo lee
# sólo el backend, no el proveedor de IA).
#
# Está separado del bucket de fotos de perfil (STORAGE_S3_*) para permitir
# credenciales / cuotas / observabilidad independientes.
AI_KB_STORAGE_S3_ENDPOINT=
AI_KB_STORAGE_S3_REGION=
AI_KB_STORAGE_S3_BUCKET=
AI_KB_STORAGE_S3_ACCESS_KEY_ID=
AI_KB_STORAGE_S3_SECRET_ACCESS_KEY=

# URL pública base. En Spaces se arma como
# https://<bucket>.<region>.digitaloceanspaces.com. Solo se usa si el bucket
# está marcado público y se quieren exponer URLs directas. Para la indexación
# remota DO no necesita acceso público.
AI_KB_STORAGE_S3_PUBLIC_BASE_URL=

# Path-style: false en Spaces (virtual-hosted); true solo en MinIO.
# [OPCIONAL — default false]
AI_KB_STORAGE_S3_PATH_STYLE=false

# Prefijo dentro del bucket para los binarios de la KB.
# [OPCIONAL — default ai-knowledge-base]
AI_KB_STORAGE_KEY_PREFIX=ai-knowledge-base


# -----------------------------------------------------------------------------
# CHATBOT INSTITUCIONAL — Invocación del agente (RF29, RF31, RF32, RF34)
# -----------------------------------------------------------------------------
# URL de invocación del agente (chat completions). En DigitalOcean Gradient cada
# agente deployado tiene su propio dominio (formato {id}.agents.do-ai.run); esa
# URL NO coincide con el management API (api.digitalocean.com/v2/gen-ai/*).
#
# Estrategia híbrida:
#   - Si esta variable se setea, el backend la usa directamente.
#   - Si queda vacía, el backend la descubre llamando al management API
#     (GET /v2/gen-ai/agents/{uuid} -> deployment.url) y la cachea en BD
#     (columna agent_invocation_url de ai_agent_configuration). Endpoint
#     admin para forzar redescubrimiento:
#         POST /api/admin/ai-agent/configuration/clear-invocation-url-cache
#
# Recomendación: setear la ENV en producción para ahorrar una llamada al
# management API en cada arranque o cache-miss. Dejarla vacía es válido
# siempre que DIGITALOCEAN_AGENT_UUID esté configurado.
# [OPCIONAL — si está vacía, se descubre dinámicamente]
# Solo el dominio base, sin el path. El adapter agrega /api/v1/chat/completions automáticamente
DIGITALOCEAN_AGENT_INVOCATION_URL=

# Access Key del endpoint del agente (chat completions).
# IMPORTANTE: es DISTINTA del DIGITALOCEAN_ACCESS_TOKEN (Personal Access Token).
# Cada agente deployado en DigitalOcean Gradient genera su propia key en la
# sección "Endpoint Keys" del dashboard del agente. Esta key es la única que
# autentica contra /api/v1/chat/completions.
#
# Síntoma cuando esta variable está mal/vacía:
#   - Management API funciona (GET/PUT /v2/gen-ai/agents/{uuid} con el PAT).
#   - Pero TODOS los mensajes del chatbot devuelven fallback ("El asistente
#     no esta disponible") porque el endpoint del agente responde 401 sin body.
#
# Cómo obtenerla:
#   1. Ir al dashboard del agente en https://cloud.digitalocean.com/gen-ai/agents/<UUID>
#   2. Sección "Endpoint Keys" o equivalente.
#   3. Generar o copiar una key existente.
# [REQUERIDA si se usa el módulo IA]
DIGITALOCEAN_AGENT_ACCESS_KEY=

# Override opcional del modelo a usar en cada invocación al agente. Cuando se
# llama al endpoint con ?agent=true, DigitalOcean usa el modelo configurado
# en el dashboard del agente; esta variable permite forzar otro modelo
# específico (útil para A/B testing o staging).
#
# Si queda vacía, el campo "model" se omite del body del request y el agente
# usa su modelo default. Valores aceptados: el nombre exacto del modelo en
# DO (ej. "llama3.3-70b-instruct").
# [OPCIONAL — default vacío (usa el del agente)]
DIGITALOCEAN_AGENT_INVOCATION_MODEL=

# Read timeout específico del probe del health-check del módulo IA, en
# milisegundos. Más corto que DO_READ_TIMEOUT_MS (default 20s) para que el
# endpoint GET /api/admin/ai-agent/configuration/health no cuelgue cuando el
# agente está caído. El probe es una invocación mínima ("ping"); un agente
# sano responde en menos de 2 segundos, así que 5s deja margen razonable.
# [OPCIONAL — default 5000]
DO_PROBE_READ_TIMEOUT_MS=5000
