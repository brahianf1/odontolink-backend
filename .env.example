# =============================================================================
# ODONTOLINK - ENVIRONMENT VARIABLES TEMPLATE
# =============================================================================
# This file is the contract between the application and its environment.
# Copy it to .env for local development. In production, all of these values
# MUST be injected through the Dokploy UI (Application > Environment).
#
# Conventions:
#   - Variables marked [REQUIRED] have no application-side default. Missing
#     them aborts startup. This is intentional (Zero-Trust).
#   - Variables marked [OPTIONAL] fall back to a safe default defined in
#     application*.properties. Override them only when needed.
# =============================================================================


# -----------------------------------------------------------------------------
# SPRING PROFILE
# -----------------------------------------------------------------------------
# Selects which application-<profile>.properties is layered on top of the
# base configuration. In Dokploy use 'prod'.
#   dev  -> verbose logging, ddl-auto=create, devtools enabled
#   test -> moderate logging, ddl-auto=update
#   prod -> minimal logging, ddl-auto=validate, hardened error responses
# [REQUIRED in production deployments]
SPRING_PROFILES_ACTIVE=dev


# -----------------------------------------------------------------------------
# DATABASE — canonical Spring Boot property names
# -----------------------------------------------------------------------------
# Full JDBC URL. In Dokploy paste the 'Internal Connection URL' provided by
# the MySQL service, replacing the host with the MySQL service name on the
# dokploy-network overlay. Example (production):
#   jdbc:mysql://odontolink-db-4qssmj:3306/odontolink?sslMode=DISABLED&allowPublicKeyRetrieval=true&serverTimezone=America/Argentina/Buenos_Aires
#
# Notes:
#   - sslMode is camelCase (MySQL Connector/J). 'sslmode' is silently ignored.
#   - sslMode=DISABLED is recommended for the internal overlay network;
#     traffic never leaves the private Docker network.
#   - allowPublicKeyRetrieval=true is needed when the MySQL account uses
#     caching_sha2_password over a non-TLS connection.
# [REQUIRED]
SPRING_DATASOURCE_URL=jdbc:mysql://localhost:3306/odontolink?sslMode=DISABLED&allowPublicKeyRetrieval=true&serverTimezone=America/Argentina/Buenos_Aires

# Database account. In production create a dedicated, least-privilege user;
# do not deploy with 'root'.
# [REQUIRED]
SPRING_DATASOURCE_USERNAME=odontolink_app

# Database password.
# Recommendation: minimum 16 chars, mixed case, digits and symbols.
# [REQUIRED]
SPRING_DATASOURCE_PASSWORD=your_secure_database_password_here


# -----------------------------------------------------------------------------
# JWT
# -----------------------------------------------------------------------------
# Signing secret. CRITICAL — must be unique per environment.
# Generate with: openssl rand -hex 64
# Minimum 256 bits (>= 64 hex characters).
# [REQUIRED]
JWT_SECRET=generate_a_secure_random_secret_key_here_minimum_64_chars

# Token lifetime in milliseconds. 86400000 = 24h, 3600000 = 1h, 604800000 = 7d.
# [OPTIONAL — default 86400000]
JWT_EXPIRATION=86400000


# -----------------------------------------------------------------------------
# HTTP SERVER
# -----------------------------------------------------------------------------
# Port the JVM listens on inside the container. Dokploy/Traefik publishes it
# externally based on the value configured in the application UI; keep them
# aligned.
# [OPTIONAL — default 8080]
SERVER_PORT=8080


# -----------------------------------------------------------------------------
# CORS
# -----------------------------------------------------------------------------
# Comma-separated list of allowed origins. In production list ONLY the real
# frontend domains. Wildcards are not appropriate when credentials are used.
# [OPTIONAL — default http://localhost:3000]
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:4200


# -----------------------------------------------------------------------------
# OBSERVABILITY
# -----------------------------------------------------------------------------
# Root log level. The prod profile already forces WARN at the root and INFO
# for application packages, so this mostly matters for dev/test.
# Valid: TRACE, DEBUG, INFO, WARN, ERROR
# [OPTIONAL — default INFO]
LOG_LEVEL=INFO


# -----------------------------------------------------------------------------
# BUSINESS RULES
# -----------------------------------------------------------------------------
# Slot generation strategy used by AvailabilityGenerationService.
#   FIXED   -> 30-minute fixed intervals
#   DYNAMIC -> slots sized by the real treatment duration
# [OPTIONAL — default FIXED]
SLOT_GENERATION_STRATEGY=FIXED


# -----------------------------------------------------------------------------
# JPA / HIBERNATE (advanced — leave unset in production)
# -----------------------------------------------------------------------------
# The prod profile pins spring.jpa.hibernate.ddl-auto=validate regardless of
# this variable, which is the safe production behavior. Override only in dev
# or test if you know what you are doing.
# Valid: none | validate | update | create | create-drop
# [OPTIONAL — default update; ignored when SPRING_PROFILES_ACTIVE=prod]
DDL_AUTO=update

# Toggle SQL echoing. Should remain false in production.
# [OPTIONAL — default false]
SHOW_SQL=false

# Toggle pretty-printed SQL in logs. Should remain false in production.
# [OPTIONAL — default false]
FORMAT_SQL=false
